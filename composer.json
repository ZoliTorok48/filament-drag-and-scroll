{
    "name": "zoltantorok/filament-drag-and-scroll",
    "description": "Shift + Drag to scroll Filament tables horizontally. Designed for users with basic mice or accessibility needs.",
    "keywords": [
        "filament",
        "laravel",
        "filament-plugin",
        "drag-scroll",
        "horizontal-scroll",
        "table",
        "accessibility"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/ZoliTorok48/filament-drag-and-scroll",
    "support": {
        "issues": "https://github.com/ZoliTorok48/filament-drag-and-scroll/issues",
        "source": "https://github.com/ZoliTorok48/filament-drag-and-scroll"
    },
    "autoload": {
        "psr-4": {
            "ZoltanTorok\\FilamentDragAndScroll\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Zoltán Török",
            "email": "torokzoltan0348@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0"
    },
    "scripts": {
        "post-install-cmd": [
            "php scripts/build-assets.php"
        ],
        "post-update-cmd": [
            "php scripts/build-assets.php"
        ],
        "post-autoload-dump": [
            "@php -r \"if (function_exists('opcache_reset')) opcache_reset();\""
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "ZoltanTorok\\FilamentDragAndScroll\\FilamentDragAndScrollServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
