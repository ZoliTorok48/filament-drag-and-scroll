{
    "name": "filament-drag-and-scroll",
    "private": true,
    "version": "1.0.0",
    "description": "Build scripts for Filament Drag and Scroll assets",
    "scripts": {
        "build": "npm run build:css && npm run build:js",
        "build:css": "npm run clean:css && npm run minify:css",
        "build:js": "npm run clean:js && npm run minify:js",
        "clean:css": "rimraf resources/dist/css",
        "clean:js": "rimraf resources/dist/js",
        "minify:css": "mkdirp resources/dist/css && cleancss -o resources/dist/css/filament-drag-and-scroll.min.css resources/css/filament-drag-and-scroll.css",
        "minify:js": "mkdirp resources/dist/js && terser resources/js/filament-drag-and-scroll.js -o resources/dist/js/filament-drag-and-scroll.min.js -c -m",
        "watch": "npm-run-all --parallel watch:*",
        "watch:css": "chokidar \"resources/css/**/*.css\" -c \"npm run build:css\"",
        "watch:js": "chokidar \"resources/js/**/*.js\" -c \"npm run build:js\"",
        "dev": "npm run build && npm run watch",
        "prepare": "npm run build"
    },
    "devDependencies": {
        "chokidar-cli": "^3.0.0",
        "clean-css-cli": "^5.6.3",
        "mkdirp": "^3.0.1",
        "npm-run-all": "^4.1.5",
        "rimraf": "^5.0.5",
        "terser": "^5.26.0"
    }
}